# --- Rust / Cargo ---
/target/
**/*.rs.bk
# Cargo.lock IS committed: Vitrine ships binaries, so the lockfile is tracked.

# --- Meson / build outputs ---
/build/
/builddir/
/_build/
/build-dir/

# --- Flatpak ---
/.flatpak-builder/
/repo/
/repo-release/
/build-dir-release/
*.flatpak

# --- Debug logs ---
# debug-run.sh writes one timestamped log per run into Troubleshoot/. They are
# regenerable and large (a single --cold run reached 4.3MB), so the register and
# any hand-written notes are tracked but the raw logs are not.
/Troubleshoot/*.log

# --- Blueprint ---
# Compiled *.ui XML is a build artifact generated into the build dir, never in-tree.

# --- Local planning docs (context for Claude, not repo content) ---
/gallery-viewer-design-notes.md
/gallery-viewer-plan.pptx
# HISTORY.md is the internal narrative record (brief -> now: root causes,
# reverts, open questions). Internal use only — deliberately not published.
/HISTORY.md

# --- Editors / OS ---
*.swp
*~
.idea/
.vscode/
.DS_Store

# LibreOffice lock files
.~lock.*#
